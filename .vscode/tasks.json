{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Project",
            "type": "shell",
            "command": "west",
            "args": [
                "build",
                "--build-dir",
                "build",
                "-b",
                "DW010-3405-WQK-5//ns",
                "openair/applications/moto_tag",
                "--sysbuild",
                "-T",
                "applications.moto_tag.dvt.atm"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Start Debug Server",
            "type": "shell",
            "command": "west",
            "args": [
                "debugserver",
                "--device=69668021",
                "--jlink"
            ],
            "isBackground": true,
            "problemMatcher": []
        }
    ]
}