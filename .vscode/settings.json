{
  // 固定保存到 static/images/posts 目录
  "pasteImage.path": "${projectRoot}/static/images/posts",
  "pasteImage.basePath": "${projectRoot}",
  
  // 生成绝对路径引用
  "pasteImage.insertPattern": "![${imageFileNameWithoutExt}](/images/posts/${imageFileName})",
  
  // 使用时间戳避免重名
  "pasteImage.defaultName": "YYYYMMDD-HHmmss",
  
  // 按文章添加前缀
  "pasteImage.namePrefix": "${currentFileNameWithoutExt}-",
  
  // 强制使用 Unix 路径分隔符
  "pasteImage.forceUnixStyleSeparator": true,
  
  // 不弹出提示
  "pasteImage.prompt": false
}